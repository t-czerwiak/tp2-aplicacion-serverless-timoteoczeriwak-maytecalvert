---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout title="Mi perfil | NASA Explorer">
  <Header />

  <main class="page">
    <div class="profile-card">

      <div class="avatar-section">
        <div class="avatar" id="avatar-initials">?</div>
        <div class="avatar-info">
          <span class="avatar-username" id="display-username">Cargando...</span>
          <span class="avatar-email" id="display-email"></span>
        </div>
      </div>

      <div class="divider"></div>

      <section class="card-section">
        <h2>Cuenta</h2>
        <div class="info-row">
          <span class="info-label">Email</span>
          <span class="info-value" id="info-email">—</span>
        </div>
        <div class="info-row">
          <span class="info-label">Miembro desde</span>
          <span class="info-value" id="info-since">—</span>
        </div>
      </section>

      <div class="divider"></div>

      <section class="card-section">
        <h2>Nombre de usuario</h2>
        <form class="profile-form" id="username-form">
          <div class="input-group">
            <input id="username" type="text" placeholder="Escribí tu nuevo username" required autocomplete="off" />
          </div>
          <p id="msg"></p>
          <button type="submit">Guardar cambios</button>
        </form>
      </section>

      <div class="divider"></div>

      <section class="card-section">
        <button class="signout-btn" id="signout-btn">Cerrar sesion</button>
      </section>

    </div>
  </main>
</Layout>

<script>
  import { getUser, getProfile, updateProfile, signOut } from "../lib/api";

  const { data: { user } } = await getUser();
  if (!user) { window.location.href = "/login"; }

  const { data: profile } = await getProfile(user.id);

  const username = profile?.username ?? user.email?.split("@")[0] ?? "usuario";
  const initial = username.charAt(0).toUpperCase();

  document.getElementById("avatar-initials").textContent = initial;
  document.getElementById("display-username").textContent = `@${username}`;
  document.getElementById("display-email").textContent = user.email ?? "";
  document.getElementById("info-email").textContent = user.email ?? "—";
  document.getElementById("info-since").textContent = new Date(user.created_at).toLocaleDateString("es-AR", {
    year: "numeric", month: "long", day: "numeric"
  });

  const input = document.getElementById("username") as HTMLInputElement;
  if (profile?.username) input.value = profile.username;

  document.getElementById("username-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const newUsername = input.value.trim();
    const msg = document.getElementById("msg");
    const btn = (e.target as HTMLFormElement).querySelector("button");
    if (!newUsername) return;

    btn.textContent = "Guardando...";
    btn.disabled = true;

    const { error } = await updateProfile(user.id, { username: newUsername });

    if (error) {
      msg.className = "msg-error";
      msg.textContent = error.message;
    } else {
      msg.className = "msg-success";
      msg.textContent = "Username actualizado correctamente.";
      document.getElementById("display-username").textContent = `@${newUsername}`;
      document.getElementById("avatar-initials").textContent = newUsername.charAt(0).toUpperCase();
    }

    btn.textContent = "Guardar cambios";
    btn.disabled = false;
  });

  document.getElementById("signout-btn")?.addEventListener("click", async () => {
    await signOut();
    window.location.href = "/login";
  });
</script>

<style>
  :global(body) {
    margin: 0;
    font-family: "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #111827, #020617);
    color: #e2e8f0;
  }

  .page {
    min-height: calc(100vh - 80px);
    display: grid;
    place-items: center;
    padding: 24px;
  }

  .profile-card {
    width: 100%;
    max-width: 480px;
    background: #111827;
    border: 1px solid rgba(148, 163, 184, 0.15);
    border-radius: 24px;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }

  .avatar-section {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 28px 28px 24px;
  }

  .avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #818cf8, #22d3ee);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    font-weight: 700;
    color: #020617;
    flex-shrink: 0;
  }

  .avatar-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .avatar-username {
    font-size: 1.1rem;
    font-weight: 700;
    color: #f8fafc;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .avatar-email {
    font-size: 0.85rem;
    color: #64748b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .divider {
    height: 1px;
    background: rgba(148, 163, 184, 0.12);
  }

  .card-section {
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  h2 {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #475569;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .info-label {
    font-size: 0.9rem;
    color: #64748b;
    flex-shrink: 0;
  }

  .info-value {
    font-size: 0.9rem;
    color: #cbd5e1;
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .profile-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .input-group {
    display: flex;
    align-items: center;
    background: #020617;
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .input-group:focus-within {
    border-color: #818cf8;
  }

  input {
    flex: 1;
    padding: 13px 14px;
    background: transparent;
    border: none;
    color: #f8fafc;
    font-size: 0.95rem;
    outline: none;
  }

  input::placeholder { color: #475569; }

  #msg {
    margin: 0;
    min-height: 18px;
    font-size: 0.85rem;
  }

  .msg-success { color: #4ade80; }
  .msg-error   { color: #f87171; }

  button[type="submit"] {
    padding: 13px;
    border: none;
    border-radius: 12px;
    background: #818cf8;
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type="submit"]:hover  { background: #6366f1; }
  button[type="submit"]:disabled { background: #334155; cursor: not-allowed; }

  .signout-btn {
    width: 100%;
    padding: 12px;
    border: 1px solid rgba(248, 113, 113, 0.3);
    border-radius: 12px;
    background: transparent;
    color: #f87171;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }

  .signout-btn:hover {
    background: rgba(248, 113, 113, 0.08);
    border-color: rgba(248, 113, 113, 0.6);
  }
</style>
