---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import CommentList from "../../components/CommentList.astro";
import CommentForm from "../../components/CommentForm.astro";
import FavoriteButton from "../../components/FavoriteButton.astro";
import { getBodyById, getAllBodies } from "../../lib/api";

export async function getStaticPaths() {
  const { data } = await getAllBodies();
  return (data ?? []).map(body => ({ params: { id: body.id } }));
}

const { id } = Astro.params;
const { data: body } = await getBodyById(id);
if (!body) return Astro.redirect("/");
---

<Layout title={body.name}>
  <Header />
  <main class="container">
    <div class="image-detail">
      <img src={body.image_url} alt={body.name} />
      <div class="info">
        <h1>{body.name}</h1>
        <span class="category">{body.category}</span>
        <p>{body.description}</p>
        <FavoriteButton bodyId={body.id} />
      </div>
    </div>
    <div class="comments-section">
      <CommentList bodyId={body.id} />
      <CommentForm bodyId={body.id} />
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 24px 60px;
  }

  .image-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 36px;
    margin-bottom: 48px;
    align-items: start;
  }

  .image-detail img {
    width: 100%;
    border-radius: 18px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .info h1 {
    margin: 0;
    font-size: 2.2rem;
    color: #f8fafc;
    line-height: 1.2;
  }

  .category {
    width: fit-content;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.14);
    color: #67e8f9;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .info p {
    margin: 0;
    color: #94a3b8;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .comments-section {
    border-top: 1px solid rgba(148, 163, 184, 0.12);
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  @media (max-width: 640px) {
    .image-detail {
      grid-template-columns: 1fr;
    }
  }
</style>
