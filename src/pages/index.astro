---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ImageCard from "../components/ImageCard.astro";
import { supabase } from "../lib/supabase";

const { data: spaceItems } = await supabase
  .from("celestial_bodies")
  .select("*");

const items = spaceItems ?? [];
---

<Layout title="NASA Space Explorer">
  <Header />

  <main class="container">
    <section class="hero">
      <h1>Explorá el universo</h1>
      <p>Descubrí imágenes del espacio, guardá tus favoritas y compartí comentarios.</p>
    </section>

    <section class="gallery">
      {items.map((item) => (
        <ImageCard item={item} />
      ))}
    </section>
  </main>
</Layout>

<style>
:global(body) {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: radial-gradient(circle at top, #0b1026, #020617);
  color: #e2e8f0;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 32px 24px;
}

.hero {
  text-align: center;
  margin-bottom: 40px;
}

.hero h1 {
  font-size: 3.2rem;
  color: #f8fafc;
  margin-bottom: 12px;
  text-shadow: 0 0 24px rgba(129, 140, 248, 0.45);
}

.hero p {
  color: #cbd5e1;
  font-size: 1.1rem;
}

.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}
</style>