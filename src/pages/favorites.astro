---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout title="Favoritos | NASA Explorer">
  <Header />
  <main class="page">
    <h1>Mis favoritos</h1>
    <div id="content">
      <p class="empty">Cargando...</p>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from "../lib/supabase";

  const content = document.getElementById("content");

  const { data: { user } } = await supabase.auth.getUser();

  if (!user) {
    content.innerHTML = `<p class="empty">Tenés que <a href="/login">iniciar sesión</a> para ver tus favoritos.</p>`;
  } else {
    async function loadFavorites() {
      const { data } = await supabase
        .from("favorites")
        .select("id, celestial_bodies(*)")
        .eq("user_id", user.id);

      const favs = data ?? [];

      if (favs.length === 0) {
        content.innerHTML = `<p class="empty">Todavía no guardaste ningún favorito.</p>`;
        return;
      }

      content.innerHTML = `
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">
          ${favs.map(f => `
            <div style="background:#111827;border:1px solid rgba(148,163,184,0.2);border-radius:22px;overflow:hidden;position:relative;">
              <img src="${f.celestial_bodies.image_url}" alt="${f.celestial_bodies.name}" style="width:100%;height:200px;object-fit:cover;background:#020617;display:block;" />
              <button class="remove-btn" data-fav-id="${f.id}" title="Quitar de favoritos" style="position:absolute;top:10px;right:10px;width:32px;height:32px;border-radius:50%;border:none;background:rgba(15,23,42,0.75);color:#f87171;font-size:1.1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);">✕</button>
              <div style="padding:16px;">
                <span style="padding:4px 10px;border-radius:999px;background:rgba(34,211,238,0.14);color:#67e8f9;font-size:0.8rem;font-weight:700;">${f.celestial_bodies.category}</span>
                <h3 style="color:#f8fafc;margin:8px 0 4px;">${f.celestial_bodies.name}</h3>
                <p style="color:#cbd5e1;font-size:0.9rem;margin:0;">${f.celestial_bodies.description}</p>
              </div>
            </div>
          `).join("")}
        </div>
      `;

      content.querySelectorAll(".remove-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
          await supabase.from("favorites").delete().eq("id", btn.dataset.favId);
          loadFavorites();
        });
      });
    }

    loadFavorites();
  }
</script>

<style>
  :global(body) {
    margin: 0;
    font-family: "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #111827, #020617);
    color: #e2e8f0;
  }
  .page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
  }
  h1 { color: #f8fafc; font-size: 2rem; margin-bottom: 24px; }
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .card {
    background: #111827;
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 22px;
    overflow: hidden;
  }
  .card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  background: #020617;
  }
  .info { padding: 16px; }
  .category {
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.14);
    color: #67e8f9;
    font-size: 0.8rem;
    font-weight: 700;
  }
  .info h3 { color: #f8fafc; margin: 8px 0 4px; }
  .info p { color: #cbd5e1; font-size: 0.9rem; margin: 0; }
  .empty { color: #94a3b8; }
  .empty a { color: #67e8f9; }
</style>