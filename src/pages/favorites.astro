---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout title="Favoritos | NASA Explorer">
  <Header />
  <main class="page">
    <div class="page-header">
      <h1>Mis favoritos</h1>
      <span class="count" id="fav-count" style="display:none"></span>
    </div>
    <div id="content">
      <p class="empty">Cargando...</p>
    </div>
  </main>
</Layout>

<script>
  import { getUser, getUserFavorites, removeFavorite } from "../lib/api";

  const content = document.getElementById("content");
  const favCount = document.getElementById("fav-count");
  const { data: { user } } = await getUser();

  if (!user) {
    window.location.href = "/login";
  } else {
    async function loadFavorites() {
      const { data } = await getUserFavorites(user.id);
      const favs = data ?? [];

      if (favs.length === 0) {
        favCount.style.display = "none";
        content.innerHTML = `
          <div class="empty-state">
            <p class="empty-title">Todavia no tenes favoritos</p>
            <p class="empty-sub">Explora el universo y guarda los que mas te gusten.</p>
            <a href="/" class="explore-btn">Explorar</a>
          </div>
        `;
        return;
      }

      favCount.textContent = `${favs.length} guardado${favs.length !== 1 ? "s" : ""}`;
      favCount.style.display = "inline-block";

      content.innerHTML = `<div class="grid">${favs.map(f => `
        <div class="fav-card">
          <a href="/image/${f.celestial_bodies.id}" class="card-link">
            <div class="card-image-wrap">
              <img src="${f.celestial_bodies.image_url}" alt="${f.celestial_bodies.name}" class="card-img" />
              <div class="card-overlay"></div>
              <span class="card-category">${f.celestial_bodies.category}</span>
            </div>
            <div class="card-body">
              <h3 class="card-name">${f.celestial_bodies.name}</h3>
              <p class="card-desc">${f.celestial_bodies.description}</p>
            </div>
          </a>
          <button class="remove-btn" data-user-id="${user.id}" data-body-id="${f.celestial_bodies.id}" title="Quitar de favoritos">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      `).join("")}</div>`;

      content.querySelectorAll(".remove-btn").forEach(btn => {
        btn.addEventListener("click", async (e) => {
          e.preventDefault();
          btn.disabled = true;
          await removeFavorite(btn.dataset.userId, btn.dataset.bodyId);
          loadFavorites();
        });
      });
    }

    loadFavorites();
  }
</script>

<style is:global>
  :global(body) {
    margin: 0;
    font-family: "Segoe UI", sans-serif;
    background: radial-gradient(circle at top, #111827, #020617);
    color: #e2e8f0;
  }

  .page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px 60px;
  }

  .page-header {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 32px;
  }

  h1 {
    margin: 0;
    color: #f8fafc;
    font-size: 2rem;
  }

  .count {
    font-size: 0.85rem;
    color: #475569;
    font-weight: 500;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .fav-card {
    position: relative;
    background: #111827;
    border: 1px solid rgba(148, 163, 184, 0.15);
    border-radius: 20px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .fav-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border-color: rgba(148, 163, 184, 0.3);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image-wrap {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .fav-card:hover .card-img {
    transform: scale(1.04);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17, 24, 39, 0.7) 0%, transparent 50%);
  }

  .card-category {
    position: absolute;
    bottom: 10px;
    left: 12px;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.18);
    color: #67e8f9;
    font-size: 0.75rem;
    font-weight: 700;
    backdrop-filter: blur(4px);
  }

  .card-body {
    padding: 14px 16px 18px;
  }

  .card-name {
    margin: 0 0 6px;
    color: #f8fafc;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .card-desc {
    margin: 0;
    color: #64748b;
    font-size: 0.85rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .remove-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: rgba(15, 23, 42, 0.7);
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(6px);
    transition: background 0.15s, color 0.15s;
  }

  .remove-btn:hover {
    background: rgba(239, 68, 68, 0.85);
    color: white;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    text-align: center;
    gap: 10px;
  }

  .empty-title {
    margin: 0;
    color: #f8fafc;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .empty-sub {
    margin: 0;
    color: #475569;
    font-size: 0.9rem;
  }

  .explore-btn {
    margin-top: 8px;
    padding: 10px 24px;
    border-radius: 12px;
    background: #818cf8;
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background 0.15s;
  }

  .explore-btn:hover { background: #6366f1; }
</style>
