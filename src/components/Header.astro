<header class="header">
  <a href="/" class="logo">
    <span class="logo-icon">✦</span>
    NASA Explorer
  </a>

  <nav>
    <a href="/">Inicio</a>
    <a href="/favorites">Favoritos</a>
    <a href="/login" id="auth-link">Ingresar</a>
  </nav>
</header>

<script>
  import { supabase } from "../lib/supabase";

  const authLink = document.getElementById("auth-link");

  const { data: { user } } = await supabase.auth.getUser();

  if (user && authLink) {
    const profileLink = document.createElement("a");
    profileLink.textContent = "Mi perfil";
    profileLink.href = "/profile";
    authLink.before(profileLink);

    authLink.textContent = "Cerrar sesión";
    authLink.href = "#";
    authLink.classList.add("logout-btn");
    authLink.addEventListener("click", async (e) => {
      e.preventDefault();
      await supabase.auth.signOut();
      window.location.href = "/";
    });
  }
</script>

<style>
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 32px;
    background-color: #0b1026;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.3rem;
    font-weight: bold;
    color: #f8fafc;
    text-decoration: none;
  }

  .logo-icon {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: linear-gradient(135deg, #818cf8, #22d3ee);
    font-size: 1rem;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  nav a {
    padding: 7px 14px;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  nav a:hover {
    color: #f8fafc;
    background: rgba(148, 163, 184, 0.08);
  }

  nav :global(.logout-btn) {
    color: #f87171;
    border: 1px solid rgba(248, 113, 113, 0.3);
  }

  nav :global(.logout-btn:hover) {
    background: rgba(248, 113, 113, 0.1);
    color: #fca5a5;
  }
</style>
