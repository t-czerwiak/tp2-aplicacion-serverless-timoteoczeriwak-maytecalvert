<header class="header">
  <a href="/" class="logo">
    <span class="logo-icon">✦</span>
    NASA Explorer
  </a>

  <nav>
    <a href="/" class="nav-link" data-path="/">Inicio</a>
    <a href="/favorites" class="nav-link" data-path="/favorites">Favoritos</a>

    <div class="nav-divider" id="nav-divider" style="display:none"></div>

    <a href="/profile" class="nav-profile" id="nav-profile" style="display:none">
      <span class="nav-avatar" id="nav-avatar">?</span>
      <span id="nav-username"></span>
    </a>

    <button class="signout-btn" id="signout-btn" style="display:none">Cerrar sesion</button>
    <a href="/login" class="login-btn" id="login-btn">Ingresar</a>
  </nav>
</header>

<script>
  import { getUser, getProfile, signOut } from "../lib/api";

  const { data: { user } } = await getUser();

  const navDivider  = document.getElementById("nav-divider");
  const navProfile  = document.getElementById("nav-profile");
  const navAvatar   = document.getElementById("nav-avatar");
  const navUsername = document.getElementById("nav-username");
  const signoutBtn  = document.getElementById("signout-btn");
  const loginBtn    = document.getElementById("login-btn");

  if (user) {
    const { data: profile } = await getProfile(user.id);
    const username = profile?.username ?? user.email?.split("@")[0] ?? "usuario";

    navAvatar.textContent   = username.charAt(0).toUpperCase();
    navUsername.textContent = username;

    navDivider.style.display  = "block";
    navProfile.style.display  = "flex";
    signoutBtn.style.display  = "flex";
    loginBtn.style.display    = "none";

    signoutBtn.addEventListener("click", async () => {
      await signOut();
      window.location.href = "/";
    });
  }

  const path = window.location.pathname;
  document.querySelectorAll(".nav-link").forEach(link => {
    if (link.dataset.path === path) link.classList.add("active");
  });
  if (path === "/profile") navProfile?.classList.add("active");
</script>

<style>
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 32px;
    height: 64px;
    background: rgba(11, 16, 38, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.15rem;
    font-weight: 700;
    color: #f8fafc;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .logo-icon {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: linear-gradient(135deg, #818cf8, #22d3ee);
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav-link {
    padding: 7px 12px;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #64748b;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    font-weight: 500;
  }

  .nav-link:hover { color: #cbd5e1; background: rgba(148, 163, 184, 0.07); }
  .nav-link.active { color: #f8fafc; background: rgba(148, 163, 184, 0.1); }

  .nav-divider {
    width: 1px;
    height: 20px;
    background: rgba(148, 163, 184, 0.15);
    margin: 0 6px;
  }

  .nav-profile {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 10px 5px 6px;
    border-radius: 999px;
    text-decoration: none;
    color: #94a3b8;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }

  .nav-profile:hover { background: rgba(148, 163, 184, 0.08); color: #f8fafc; }
  .nav-profile.active { color: #f8fafc; background: rgba(148, 163, 184, 0.1); }

  .nav-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: linear-gradient(135deg, #818cf8, #22d3ee);
    display: grid;
    place-items: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #020617;
    flex-shrink: 0;
  }

  .signout-btn {
    display: flex;
    align-items: center;
    padding: 7px 12px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: #64748b;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }

  .signout-btn:hover { color: #f87171; background: rgba(248, 113, 113, 0.07); }

  .login-btn {
    padding: 7px 14px;
    border-radius: 8px;
    background: #818cf8;
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }

  .login-btn:hover { background: #6366f1; }
</style>
