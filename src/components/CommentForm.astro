---
const { bodyId } = Astro.props;
---

<form class="comment-form" data-id={bodyId}>
  <input type="text" placeholder="Escribí un comentario..." />
  <button type="submit">Enviar</button>
</form>

<script>
  import { getUser, addComment } from "../lib/api";

  document.querySelectorAll(".comment-form").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const btn = form.querySelector("button");
      const input = form.querySelector("input");
      if (btn.disabled) return;
      btn.disabled = true;

      const { data: { user } } = await getUser();
      if (!user) { btn.disabled = false; window.location.href = "/login"; return; }

      const text = input.value.trim();
      const bodyId = form.dataset.id;
      if (!text) { btn.disabled = false; return; }

      const { error } = await addComment(user.id, bodyId, text);

      btn.disabled = false;

      if (!error) {
        input.value = "";
        window.dispatchEvent(new CustomEvent("comment-sent", { detail: { bodyId } }));
      }
    });
  });
</script>

<style>
  .comment-form {
    display: flex;
    gap: 8px;
  }
  input {
    flex: 1;
    min-width: 0;
    padding: 10px 12px;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 12px;
    background: #020617;
    color: #f8fafc;
    outline: none;
  }
  input::placeholder { color: #64748b; }
  button {
    padding: 10px 14px;
    border: none;
    border-radius: 12px;
    background: #818cf8;
    color: white;
    font-weight: 700;
    cursor: pointer;
  }
  button:hover { background: #6366f1; }
  button:disabled { background: #334155; cursor: not-allowed; }
</style>
