---
const { item } = Astro.props;
---

<article class="card">
  <img src={item.image_url} alt={item.title} />

  <div class="content">
    <h3>{item.title}</h3>
    <p>{item.description}</p>
    <p class="category">{item.category}</p>

    <div class="actions">
      <a href={`/image/${item.id}`}>Ver detalle</a>
      <button>Favorito</button>
    </div>
  </div>
</article>

<style>
  .card {
    background-color: #ffffff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }

  .content {
    padding: 18px;
  }

  h3 {
    margin-top: 0;
    color: #1e1b4b;
  }

  p {
    color: #475569;
  }

  .category {
    font-weight: bold;
    color: #7c3aed;
  }

  .actions {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }

  a,
  button {
    padding: 10px 12px;
    border-radius: 10px;
    border: none;
    background-color: #c7d2fe;
    color: #312e81;
    text-decoration: none;
    cursor: pointer;
  }
</style>